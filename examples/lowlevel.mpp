// Low-level memory (C++ power) - mem_alloc, mem_read8, mem_write8
// Run with C++ implementation: cpp\mpp.exe -r lowlevel.mpp

let buf = mem_alloc(16)
mem_write8(buf, 0, 72)   // 'H'
mem_write8(buf, 1, 105)  // 'i'
mem_write8(buf, 2, 33)   // '!'

print("Bytes written:")
print(mem_read8(buf, 0))
print(mem_read8(buf, 1))
print(mem_read8(buf, 2))
